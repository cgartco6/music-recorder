<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>AI Music Recorder Pro</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            min-height: 100vh;
            padding: 20px;
        }
        #app { max-width: 1400px; margin: 0 auto; }
        .header {
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 20px;
            margin-bottom: 20px;
            color: white;
        }
        .controls { display: flex; gap: 15px; flex-wrap: wrap; margin: 15px 0; }
        button {
            padding: 12px 24px;
            font-size: 16px;
            border: none;
            border-radius: 40px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.2s;
        }
        button:active { transform: scale(0.96); }
        .btn-rec { background: #e74c3c; color: white; }
        .btn-stop { background: #f39c12; color: white; }
        .btn-download { background: #2ecc71; color: white; }
        .btn-upload { background: #3498db; color: white; }
        .grid-2col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        .card {
            background: rgba(255,255,255,0.95);
            border-radius: 24px;
            padding: 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }
        .character-canvas {
            width: 100%;
            aspect-ratio: 1/1;
            background: #2c3e50;
            border-radius: 20px;
            cursor: pointer;
        }
        .instruments-panel {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            margin-top: 15px;
        }
        .instrument-icon {
            background: #ecf0f1;
            padding: 10px;
            border-radius: 60px;
            text-align: center;
            flex: 1;
        }
        .recording-list {
            max-height: 300px;
            overflow-y: auto;
        }
        .status {
            background: #2c3e50;
            padding: 12px;
            border-radius: 30px;
            margin-top: 15px;
            text-align: center;
        }
        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.6; } }
        .recording { animation: pulse 1s infinite; background: #e67e22; }
        @media (max-width: 800px) {
            .grid-2col { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div id="app"></div>
</body>
</html>
